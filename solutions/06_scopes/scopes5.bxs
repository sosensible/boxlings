// This exercise is already correct - demonstrates server scope
function main() {
    server.myCounter = (server.myCounter ?: 0) + 1;
    
    println( "This script has been run #server.myCounter# time(s)" );
    println( "" );
    println( "Run this script multiple times to see the counter increase!" );
    println( "The server scope persists across executions." );
}

main();
