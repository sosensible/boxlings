class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Scopes Exercise 3 - arguments scope", () => {
            it( "should greet correctly using arguments", () => {
                savecontent variable="output" {
                    include "scopes3.bxs"
                }
                expect( output ).toInclude( "Hello, BoxLang!" )
            })
        })
    }
}
