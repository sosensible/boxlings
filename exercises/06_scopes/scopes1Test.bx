class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Scopes Exercise 1 - variables scope", () => {
            it( "should access unscoped variables from variables scope", () => {
                savecontent variable="output" {
                    include "scopes1.bxs"
                }
                expect( output ).toInclude( "x is: 10" )
            })
        })
    }
}
