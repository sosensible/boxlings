/**
 * TestBox Test for functional2
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Functional 2 - filter", () => {
            it( "filters even numbers", () => {
                include "functional2.bxs"
                expect( variables.result ).toBe( [ 2, 4, 6 ] )
            })
        })
    }
}
