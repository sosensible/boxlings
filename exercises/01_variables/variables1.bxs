// In BoxLang, variables inside functions are automatically local-scoped!
// This is different from CFML where you need the `var` keyword.
// However, using `var` is still a good practice for clarity.
//
// TODO: This code works as-is, but add `var` for better readability!

function main() {
    var x = 5;
    // x = 5;  // This works, but it's better to declare with `var` for clarity --- IGNORE ---
    println( "local variable [x] has the value #x#" );
}

main();
