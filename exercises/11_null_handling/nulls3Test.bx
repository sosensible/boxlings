/**
 * TestBox Test for nulls3
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Null Handling 3 - Missing Key", () => {
            it( "defaults when key is missing", () => {
                include "nulls3.bxs"
                expect( variables.result ).toBe( "missing" )
            })
        })
    }
}
