class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Structs Exercise 3 - Member Functions", () => {
            it( "should count keys correctly", () => {
                include "structs3.bxs";
                expect( variables.count ).toBe( 3 );
            });
            
            it( "should check key existence", () => {
                include "structs3.bxs";
                expect( variables.hasMath ).toBeTrue();
            });
        });
    }
}
