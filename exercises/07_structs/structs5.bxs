// TODO: Convert to ordered struct to preserve order

function main() {
    // Regular struct - order not guaranteed
    var steps = {
        first: "Wash",
        second: "Rinse",
        third: "Dry"
    }
    
    // We need order preserved!
    steps.each( (key, value) => {
        println( "#key#: #value#" )
    })
}

main()
