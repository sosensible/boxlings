function main() {
    var isActive = "true";  // This is a STRING, not a boolean!
    var count = 0
    
    if ( isActive ) {
        println( "System is active" )
    }
    
    // In BoxLang, 0 is falsey
    if ( count ) {
        println( "Count is truthy" )
    } else {
        println( "Count is falsey" )
    }
}

main()
