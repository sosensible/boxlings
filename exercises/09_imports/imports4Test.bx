class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Imports Exercise 4 - Using Imports", () => {
            it( "should create and use HashMap", () => {
                var importsClass = new imports4()
                
                savecontent variable="output" {
                    importsClass.main( [] )
                }
                
                expect( output ).toInclude( "Language: BoxLang" )
            })
        })
    }
}
