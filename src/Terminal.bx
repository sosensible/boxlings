 *
 * Handles terminal output, colors, and formatting with ANSI support
 */
class {

    // ANSI Color Codes
    property name="RESET";
    property name="BOLD";
    property name="RED";
    property name="GREEN";
    property name="YELLOW";
    property name="BLUE";
    property name="MAGENTA";
    property name="CYAN";
    property name="WHITE";

    function init() {
        // ANSI escape codes
        variables.ESC = char(27);
        variables.RESET = variables.ESC & "[0m";
        variables.BOLD = variables.ESC & "[1m";
        variables.RED = variables.ESC & "[31m";
        variables.GREEN = variables.ESC & "[32m";
        variables.YELLOW = variables.ESC & "[33m";
        variables.BLUE = variables.ESC & "[34m";
        variables.MAGENTA = variables.ESC & "[35m";
        variables.CYAN = variables.ESC & "[36m";
        variables.WHITE = variables.ESC & "[37m";
        return this;
    }

    /**
     * Get ANSI 256-color code
     * @param colorCode The color code (0-255)
     * @return ANSI escape sequence for the color
     */
    function ansi256( required numeric colorCode ) {
        return variables.ESC & "[38;5;" & colorCode & "m";
    }

    /**
     * Get ANSI 256-color code by name (CommandBox style)
     * @param colorName The color name (e.g., "color81", "color196")
     * @return ANSI escape sequence for the color
     */
    function getColorCode( required string colorName ) {
        // Extract number from "colorXXX" format
        var colorNum = replaceNoCase( colorName, "color", "" );
        if ( isNumeric( colorNum ) ) {
            return ansi256( colorNum );
        }
        return variables.RESET;
    }

    /**
     * Print text with 256-color support
     * @param text The text to print
     * @param colorCode The color code (0-255) or color name (e.g., "color81")
     */
    function printLine( required string text = "", any color = "" ) {
        if ( color != "" ) {
            var colorCode = isNumeric( color ) ? ansi256( color ) : getColorCode( color );
            println( colorCode & text & variables.RESET );
        } else {
            println( text );
        }
    }

