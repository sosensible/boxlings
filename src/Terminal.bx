    /**
     * Show welcome message with enhanced formatting
     */
    function showWelcome() {
        CLIClear();

        showBoxLangBanner();

        printColoredDivider( "═", 64, "color81" );
        println( "" );

        printBold( "Welcome to BoxLings! 🥊" );
        println( "" );
        println( "Learn BoxLang + Test-Driven Development through hands-on exercises." );
        println( "" );

        printLine( "HOW IT WORKS:", "color226" );
        println( "  📖 For exercises with tests → Read the test file FIRST" );
        println( "  💡 Tests tell you exactly what your code should do" );
        println( "  ✏️  Fix the exercise until tests pass" );
        println( "  🧪 Later, you'll write your own tests!" );
        println( "" );

        printLine( "KEYBOARD SHORTCUTS:", "color226" );
        println( "  n → Next exercise (after completing current)" );
        println( "  h → Show hint" );
        println( "  t → Show test file" );
        println( "  l → List all exercises" );
        println( "  r → Rerun current exercise" );
        println( "  q → Quit" );
        println( "" );

        printColoredDivider( "═", 64, "color81" );
        println( "" );
        print( "Press ENTER to start learning... " );

        CLIRead();
        CLIClear();
    }

    /**
     * Print text in a box
     */
    function printBoxed( required array lines ) {
        var maxLen = 0;
        lines.each( line => {
            if ( line.len() > maxLen ) {
                maxLen = line.len();
            }
        });

        println( "╔" & repeatString( "═", maxLen + 2 ) & "╗" );
        lines.each( line => {
            var padding = repeatString( " ", maxLen - line.len() );
            println( "║ #line##padding# ║" );
        });
        println( "╚" & repeatString( "═", maxLen + 2 ) & "╝" );
    }

    /**
     * Print text in a colored box
     *
     * @param lines  Array of strings OR a single multi-line string to display inside the box
     * @param color  Border color: named ("blue", "green", etc.) or 256-color number/name
     */
    function printBoxedColor( required any content, any color = "blue" ) {
        // Normalise to array of lines
        var lines = isArray( content )
            ? content
            : content.listToArray( char( 10 ) );

        // Determine the ANSI color code
        var colorCode = variables.RESET;
        if ( isNumeric( color ) ) {
            colorCode = ansi256( color );
        } else {
            switch ( color ) {
                case "red":     colorCode = variables.RED;     break;
                case "green":   colorCode = variables.GREEN;   break;
                case "yellow":  colorCode = variables.YELLOW;  break;
                case "blue":    colorCode = variables.BLUE;    break;
                case "magenta": colorCode = variables.MAGENTA; break;
                case "cyan":    colorCode = variables.CYAN;    break;
                default:
                    // Try to resolve as a 256-color name like "color81"
                    colorCode = getColorCode( color );
            }
        }

        var maxLen = 0;
        lines.each( line => {
            if ( line.len() > maxLen ) maxLen = line.len();
        });

        println( colorCode & "╔" & repeatString( "═", maxLen + 2 ) & "╗" & variables.RESET );
        lines.each( line => {
            var padding = repeatString( " ", maxLen - line.len() );
            println( colorCode & "║" & variables.RESET & " #line##padding# " & colorCode & "║" & variables.RESET );
        });
        println( colorCode & "╚" & repeatString( "═", maxLen + 2 ) & "╝" & variables.RESET );
    }

    /**
     * Show completion message
     */
    function showCompletion( required string message ) {
        println( "" );
        printRainbowDivider( 64 );
        println( "" );
        printLine( "                    CONGRATULATIONS!", "color226" );
        println( "" );
        printLine( "         You've completed all BoxLings exercises!", "color46" );
        println( "" );
        printRainbowDivider( 64 );
        println( "" );

        if ( message != "" ) {
            println( message );
            println( "" );
        }
    }

    /**
     * Show progress bar with color
     */
    function showProgress( required numeric completed, required numeric total ) {
        var percentage = total > 0 ? round( (completed / total) * 100 ) : 0;
        var barWidth = 40;
        var filledWidth = round( (percentage / 100) * barWidth );

        var bar = "";
        for ( var i = 1; i <= barWidth; i++ ) {
            bar &= i <= filledWidth ? "█" : "░";
        }

        // Color based on progress (Electric theme: yellow → orange → green)
        var color = "color226";
        if ( percentage >= 75 ) {
            color = "color46";
        } else if ( percentage >= 50 ) {
            color = "color208";
        } else if ( percentage >= 25 ) {
            color = "color214";
        }

        print( variables.BOLD );
        printColor( "[#bar#] #percentage#%", color );
        print( " (#completed#/#total# exercises)" & variables.RESET );
        println( "" );
    }

    /**
     * Print with color
     */
    function printColor( required string text, string color = "default" ) {
        var colorCode = variables.RESET;

        switch( color ) {
            case "red":
                colorCode = variables.RED;
                break;
            case "green":
                colorCode = variables.GREEN;
                break;
            case "yellow":
                colorCode = variables.YELLOW;
                break;
            case "blue":
                colorCode = variables.BLUE;
                break;
            case "magenta":
                colorCode = variables.MAGENTA;
                break;
            case "cyan":
                colorCode = variables.CYAN;
                break;
        }

        println( colorCode & text & variables.RESET );
    }

    /**
     * Print success message
     */
    function printSuccess( required string text ) {
        printColor( "✅ #text#", "green" );
    }

    /**
     * Print error message
     */
    function printError( required string text ) {
        printColor( "❌ #text#", "red" );
    }

    /**
     * Print info message
     */
    function printInfo( required string text ) {
        printColor( "ℹ️  #text#", "blue" );
    }

    /**
     * Print warning message
     */
    function printWarning( required string text ) {
        printColor( "⚠️  #text#", "yellow" );
    }

    /**
     * Print hint
     */
    function printHint( required string text ) {
        printColor( "💡 #text#", "cyan" );
    }

    /**
     * Print test indicator
     */
    function printTest( required string text ) {
        printColor( "🧪 #text#", "magenta" );
    }

    /**
     * Clear terminal
     */
    function clear() {
        CLIClear();
    }

    /**
     * Print section header
     */
    function printHeader( required string text ) {
        var line = repeatString( "=", text.len() );
        println( "" );
        println( text );
        println( line );
        println( "" );
    }

    /**
     * Print section divider
     */
    function printDivider() {
        println( "────────────────────────────────────────────────────────────────" );
    }

    /**
     * Print a colored divider
     * @param char The character to use for the divider
     * @param length The length of the divider
     * @param color The color code or name
     */
    function printColoredDivider( string char = "═", numeric length = 64, any color = "color248" ) {
        printLine( repeatString( char, length ), color );
    }

    /**
     * Print text with gradient effect
     * @param text The text to print
     * @param colors Array of color codes or names
     */
    function printGradient( required string text, required array colors ) {
        var chars = listToArray( text, "" );
        var colorCount = arrayLen( colors );
        var output = "";

        for ( var i = 1; i <= arrayLen( chars ); i++ ) {
            var colorIndex = ceiling( (i / arrayLen( chars )) * colorCount );
            colorIndex = min( colorIndex, colorCount );
            var colorCode = isNumeric( colors[ colorIndex ] ) ? ansi256( colors[ colorIndex ] ) : getColorCode( colors[ colorIndex ] );
            output &= colorCode & chars[ i ];
        }

        println( output & variables.RESET );
    }

    /**
     * Print a rainbow divider
     * @param length The length of the divider
     */
    function printRainbowDivider( numeric length = 64 ) {
        var rainbowColors = [ 196, 208, 226, 46, 21, 93 ]; // Red, Orange, Yellow, Green, Blue, Purple
        var output = "";
        var colorCount = arrayLen( rainbowColors );

        for ( var i = 1; i <= length; i++ ) {
            var colorIndex = ((i - 1) % colorCount) + 1;
            output &= ansi256( rainbowColors[ colorIndex ] ) & "═";
        }

        println( output & variables.RESET );
    }

    /**
     * Print a banner with border and colors
     * @param text The text to display
     * @param borderColor The border color
     * @param textColor The text color
     */
    function printBanner( required string text, any borderColor = "color248", any textColor = "color226" ) {
        var length = text.len() + 4;
        var borderColorCode = isNumeric( borderColor ) ? ansi256( borderColor ) : getColorCode( borderColor );
        var textColorCode = isNumeric( textColor ) ? ansi256( textColor ) : getColorCode( textColor );

        printLine( "╔" & repeatString( "═", length ) & "╗", borderColor );
        println( borderColorCode & "║  " & textColorCode & text & borderColorCode & "  ║" & variables.RESET );
        printLine( "╚" & repeatString( "═", length ) & "╝", borderColor );
    }

    /**
     * Print text with bold effect
     * @param text The text to print
     */
    function printBold( required string text ) {
        println( variables.BOLD & text & variables.RESET );
    }

    /**
     * Print a spinner character (for loading animations)
     * @param step The current step (0-3)
     * @return The spinner character
     */
    function getSpinner( numeric step = 0 ) {
        var spinners = [ "⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏" ];
        return spinners[ (step % arrayLen( spinners )) + 1 ];
    }

    /**
     * Print a status line with icon
     * @param status The status (success, error, warning, info)
     * @param text The text to display
     */
    function printStatus( required string status, required string text ) {
        switch( status ) {
            case "success":
                printSuccess( text );
                break;
            case "error":
                printError( text );
                break;
            case "warning":
                printWarning( text );
                break;
            case "info":
                printInfo( text );
                break;
            default:
                println( text );
        }
    }

    /**
     * Print a table header
     * @param columns Array of column names
     * @param widths Array of column widths
     * @param colors Optional array of colors for each column (color codes or names)
     */
    function printTableHeader( required array columns, required array widths, array colors = [] ) {
        var hasColors = arrayLen( colors ) > 0;
        var header = "";

        for ( var i = 1; i <= arrayLen( columns ); i++ ) {
            var col = columns[ i ];
            var width = widths[ i ];
            var padding = repeatString( " ", width - col.len() );

            if ( hasColors && i <= arrayLen( colors ) ) {
                var colorCode = isNumeric( colors[ i ] ) ? ansi256( colors[ i ] ) : getColorCode( colors[ i ] );
                header &= variables.BOLD & colorCode & col & padding & variables.RESET & " │ ";
            } else {
                header &= variables.BOLD & col & padding & variables.RESET & " │ ";
            }
        }

        println( header );
        printDivider();
    }

    /**
     * Print a table row
     * @param values Array of cell values
     * @param widths Array of column widths
     * @param colors Optional array of colors for each column (color codes or names)
     */
    function printTableRow( required array values, required array widths, array colors = [] ) {
        var hasColors = arrayLen( colors ) > 0;
        var row = "";

        for ( var i = 1; i <= arrayLen( values ); i++ ) {
            var val = values[ i ];
            var width = widths[ i ];
            var padding = repeatString( " ", width - val.len() );

            if ( hasColors && i <= arrayLen( colors ) ) {
                var colorCode = isNumeric( colors[ i ] ) ? ansi256( colors[ i ] ) : getColorCode( colors[ i ] );
                row &= colorCode & val & padding & variables.RESET & " │ ";
            } else {
                row &= val & padding & " │ ";
            }
        }

        println( row );
    }

