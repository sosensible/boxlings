/**
 * SOLUTION: TestBox tests for testing1 (add function)
 * 
 * This is an example of what your tests should look like.
 * Students replace `expect( true ).toBeFalse()` with real assertions.
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Testing 1 - add()", () => {
            it( "returns the sum of two positive numbers", () => {
                include "testing1.bxs"
                expect( add( 2, 3 ) ).toBe( 5 )
            })
            it( "returns zero when adding inverse values", () => {
                include "testing1.bxs"
                expect( add( -5, 5 ) ).toBe( 0 )
            })
            it( "works with larger numbers", () => {
                include "testing1.bxs"
                expect( add( 100, 200 ) ).toBe( 300 )
            })
        })
    }
}
