/**
 * SOLUTION: TestBox tests for testing5 (isEven function)
 *
 * This is an example of what your tests should look like.
 * Students replace `expect( true ).toBeFalse()` with real assertions.
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Testing 5 - isEven()", () => {
            it( "returns true for even numbers", () => {
                include "testing5.bxs"
                expect( isEven( 10 ) ).toBeTrue()
                expect( isEven( 0 ) ).toBeTrue()
                expect( isEven( 2 ) ).toBeTrue()
            })
            it( "returns false for odd numbers", () => {
                include "testing5.bxs"
                expect( isEven( 3 ) ).toBeFalse()
                expect( isEven( 7 ) ).toBeFalse()
                expect( isEven( 1 ) ).toBeFalse()
            })
        })
    }
}
