/**
 * SOLUTION: TestBox tests for testing4 (sumArray function)
 *
 * This is an example of what your tests should look like.
 * Students replace `expect( true ).toBeFalse()` with real assertions.
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Testing 4 - sumArray()", () => {
            it( "sums an array of positive numbers", () => {
                include "testing4.bxs"
                expect( sumArray( [ 1, 2, 3, 4 ] ) ).toBe( 10 )
            })
            it( "returns 0 for a single-element array of 0", () => {
                include "testing4.bxs"
                expect( sumArray( [ 0 ] ) ).toBe( 0 )
            })
            it( "handles a single element", () => {
                include "testing4.bxs"
                expect( sumArray( [ 42 ] ) ).toBe( 42 )
            })
        })
    }
}
