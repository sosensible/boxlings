var people = queryNew(
    "name,age",
    "varchar,integer",
    [
        { name: "Alice", age: 30 },
        { name: "Bob",   age: 22 },
        { name: "Carol", age: 28 },
        { name: "Dave",  age: 20 }
    ]
)

var adults = queryExecute(
    "SELECT name, age FROM people WHERE age > 25",
    [],
    { dbtype: "query" }
)
