/**
 * TestBox Test for async2
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Async 2 - asyncRun with result", () => {
            it( "doubles the number asynchronously", () => {
                include "async2.bxs"
                expect( variables.result ).toBe( 42 )
            })
        })
    }
}
