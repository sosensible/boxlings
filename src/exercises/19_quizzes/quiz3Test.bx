/**
 * TestBox Test for quiz3
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Quiz 3 - OOP, Error Handling & Casting", () => {
            it( "creates player with name", () => {
                var p = new quiz3( "Alice" )
                expect( p.getName() ).toBe( "Alice" )
            })
            it( "starts with score 0", () => {
                var p = new quiz3( "Bob" )
                expect( p.getScore() ).toBe( 0 )
            })
            it( "adds points correctly", () => {
                var p = new quiz3( "Carol" )
                p.addPoints( 50 )
                p.addPoints( 30 )
                expect( p.getScore() ).toBe( 80 )
            })
            it( "returns correct grade B for 75-89", () => {
                var p = new quiz3( "Dave" )
                p.addPoints( 80 )
                expect( p.getGrade() ).toBe( "B" )
            })
            it( "returns A for >= 90", () => {
                var p = new quiz3( "Eve" )
                p.addPoints( 95 )
                expect( p.getGrade() ).toBe( "A" )
            })
            it( "returns F for < 60", () => {
                var p = new quiz3( "Frank" )
                p.addPoints( 40 )
                expect( p.getGrade() ).toBe( "F" )
            })
            it( "casts score to int", () => {
                var p = new quiz3( "Grace" )
                p.addPoints( 88 )
                expect( p.getScoreAsInt() ).toBeInstanceOf( "java.lang.Integer" )
            })
        })
    }
}
