/**
 * TestBox Test for quiz2
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Quiz 2 - Arrays, Structs & Functional", () => {
            it( "filters odd numbers", () => {
                include "quiz2.bxs"
                expect( variables.odds ).toBe( [ 1, 3, 5, 7, 9 ] )
            })
            it( "maps words to uppercase", () => {
                expect( variables.uppercased ).toBe( [ "HELLO", "WORLD", "BOXLANG" ] )
            })
            it( "reduces to sum", () => {
                expect( variables.total ).toBe( 55 )
            })
            it( "accesses nested struct value", () => {
                expect( variables.host ).toBe( "localhost" )
            })
        })
    }
}
