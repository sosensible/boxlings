/**
 * TestBox Test for structs_advanced4
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Structs Advanced 4 - Sorted Keys", () => {
            it( "sorts keys alphabetically", () => {
                include "structs_advanced4.bxs"
                expect( variables.result ).toBe( [ "a", "b", "c" ] )
            })
        })
    }
}
