class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Structs Exercise 2 - Case Insensitivity", () => {
            it( "should access keys case-insensitively", () => {
                savecontent variable="output" {
                    include "structs2.bxs"
                }
                expect( output ).toInclude( "Luis" )
                expect( output ).toInclude( "40" )
            })
        })
    }
}
