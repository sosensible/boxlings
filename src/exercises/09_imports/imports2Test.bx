class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Imports Exercise 2 - Java Imports", () => {
            it( "should import and use Java ArrayList", () => {
                // Execute the class main method
                var importsClass = new imports2()
                
                savecontent variable="output" {
                    importsClass.main( [] )
                }
                
                expect( output ).toInclude( "List size: 2" )
            })
        })
    }
}
