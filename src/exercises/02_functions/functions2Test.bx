/**
 * TestBox Test for functions2 exercise
 * 
 * READ THIS FIRST! This test checks that your function accepts arguments.
 */
class extends="testbox.system.BaseSpec" {
    
    function run() {
        describe( "Functions Exercise 2 - Arguments", () => {
            
            it( "should accept a name parameter and greet properly", () => {
                savecontent variable="output" {
                    include "functions2.bxs"
                }
                
                expect( output ).toInclude( "Hello, BoxLang!" )
                expect( output ).toInclude( "Hello, Luis!" )
            })
            
        })
    }
}
