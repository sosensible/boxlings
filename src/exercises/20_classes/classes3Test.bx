/**
 * TestBox Test for classes3 / classes3Circle
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Classes 3 - Inheritance", () => {
            it( "base class area() returns 0", () => {
                var shape = new classes3( "blue" )
                expect( shape.area() ).toBe( 0 )
            })
            it( "circle overrides area()", () => {
                var circle = new classes3Circle( "red", 5 )
                var expected = pi() * 25
                expect( circle.area() ).toBeCloseTo( expected, 4 )
            })
            it( "circle inherits describe()", () => {
                var circle = new classes3Circle( "green", 3 )
                var desc = circle.describe()
                expect( desc ).toInclude( "green" )
                expect( desc ).toInclude( "area" )
            })
        })
    }
}
