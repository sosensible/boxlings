/**
 * TestBox Test for spread2
 */
class extends="testbox.system.BaseSpec" {
    function run() {
        describe( "Spread 2 - Array Literal Spread", () => {
            it( "merges arrays using spread in a literal", () => {
                include "spread2.bxs"
                expect( variables.merged ).toBe( [ 2, 4, 6, 1, 3, 5 ] )
            })
            it( "produces correctly sorted merged array", () => {
                include "spread2.bxs"
                expect( variables.sorted ).toBe( [ 1, 2, 3, 4, 5, 6 ] )
            })
        })
    }
}
