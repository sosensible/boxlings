// In BoxLang, all variables can be reassigned - there are no true constants
// like in some other languages. However, you can use naming conventions.
//
// TODO: Fix this code by following BoxLang conventions

// Convention: Use UPPERCASE for "constant" values
variables.max_points = 100

println( "The maximum points is: #max_points#" )

// This works in BoxLang (no true constants)
variables.max_points = 200

println( "But we can still change it to: #max_points#" )
