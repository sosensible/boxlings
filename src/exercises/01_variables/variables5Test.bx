/**
 * TestBox Test for variables5 exercise
 * 
 * READ THIS FIRST! This test demonstrates variable shadowing.
 * 
 * Shadowing: You can declare a variable with the same name multiple times,
 * and each new declaration "shadows" (hides) the previous one.
 */
class extends="testbox.system.BaseSpec" {
    
    function run() {
        describe( "Variables Exercise 5 - Shadowing", () => {
            
            it( "should start with x equal to 5", () => {
                // We can't easily test intermediate values in a script
                // So we'll just verify the final result
                include "variables5.bxs"
                
                // The result variable should exist
                expect( variables ).toHaveKey( "result" )
            })
            
            it( "should end with x equal to 15", () => {
                include "variables5.bxs"
                
                // After all the shadowing:
                // x = 5
                // x = x * 2  => x = 10
                // x = x + 5  => x = 15
                expect( variables.result ).toBe( 15 )
            })
            
            it( "should demonstrate shadowing by declaring var x multiple times", () => {
                var content = fileRead( expandPath( "exercises/01_variables/variables5.bxs" ) )
                
                // The code should have multiple "var x" declarations
                var matches = reMatchNoCase( "var\s+x\s*=", content )
                expect( matches.len() ).toBeGTE( 3, "Should have at least 3 'var x' declarations" )
            })
            
        })
    }
}
