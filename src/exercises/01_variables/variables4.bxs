// In BoxLang, variables are dynamically typed.
// You can reassign them to different types!
// TODO: Fix the error in this code

function main() {
    var x = 5
    println( "x is a number: #x#" )

    x = "Hello"
    println( "x is now a string: #x#" )

    x = now()
    assert isBoolean( x ) : "Expected x to be a Boolean after reassignment, but got: #x#"
    println( "x is now a boolean: #x#" )
}

main()
